# ============================================================
# LMS BACKEND - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control!

# ============================================================
# DATABASE
# ============================================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/lms-db?retryWrites=true&w=majority

# ============================================================
# SECURITY
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================
# SERVER
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# FRONTEND URLS (CORS)
# ============================================================
# Production Frontend (Vercel)
PRODUCTION_FRONTEND_URL=https://lms-one-lyart.vercel.app

# Development Frontends (optional, for local testing)
# DEVELOPMENT_FRONTEND_URL=http://localhost:5500

# ============================================================
# OPTIONAL: FILE UPLOAD
# ============================================================
MAX_FILE_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads

# ============================================================
# OPTIONAL: EMAIL (for future features)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================================
# OPTIONAL: LOGGING
# ============================================================
LOG_LEVEL=info  # debug, info, warn, error
